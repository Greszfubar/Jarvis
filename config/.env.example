# ── Brain — uses local `claude` CLI (no API key needed) ──
# Make sure `claude` is installed: https://claude.ai/code
# JARVIS calls it via subprocess — just be logged in to Claude Code.

# ── Telegram (phone control) ───────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Start chat with your bot, visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy your numeric chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── News ───────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here        # https://newsapi.org (free tier)
# Leave blank to fall back to RSS feeds (no key needed)

# ── Weather ────────────────────────────────────────────
# Open-Meteo: completely free, no API key required
WEATHER_CITY=New York                     # Your city
WEATHER_UNITS=imperial                    # imperial or metric

# ── Google (Calendar + Gmail) ──────────────────────────
# Download credentials.json from Google Cloud Console
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json

# ── ElevenLabs (optional voice upgrade) ────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── User Profile ───────────────────────────────────────
USER_NAME=Evan
USER_TIMEZONE=America/New_York
USER_WAKE_TIME=07:00
USER_SLEEP_TIME=23:00

# ── JARVIS OS tools panel ──────────────────────────
# Password for the dashboard Tools/API-keys panel (choose your own)
JARVIS_TOOLS_PASSWORD=
